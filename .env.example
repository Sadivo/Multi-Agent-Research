# Google Gemini API Key (required)
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API Key (required)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith Tracing (optional, set to true to enable)
LANGCHAIN_TRACING_V2=true

# LangSmith API Key (optional, required if tracing is enabled)
LANGCHAIN_API_KEY=your_langchain_api_key_here

# LangSmith Project Name (optional)
LANGCHAIN_PROJECT=multi-agent-research-pipeline
